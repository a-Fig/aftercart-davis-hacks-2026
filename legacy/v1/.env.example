# ============================================================================
# ReceiptCheck — environment variables
# Copy this file to `web/.env.local` and fill in values.
# Never commit web/.env.local — it's in .gitignore.
# ============================================================================

# ----------------------------------------------------------------------------
# Cloud SQL Postgres (replaces Supabase, post-migration 2026-05-04)
# Local dev: PGHOST = Cloud SQL public IP, PGPORT/PGSSLMODE set
# Cloud Run: PGHOST = /cloudsql/<project>:<region>:<instance>, no PGPORT/PGSSLMODE
# (the Unix-socket case skips both — pg refuses SSL on a non-TCP connection)
# ----------------------------------------------------------------------------
PGHOST=
PGPORT=5432
PGUSER=aftercart_app
PGPASSWORD=
PGDATABASE=receiptcheck
PGSSLMODE=require

# Cloud SQL root password — only needed for one-time bootstrap (extensions + GRANT).
# Not used at runtime.
CLOUD_SQL_ROOT_PASSWORD=

# ----------------------------------------------------------------------------
# Vertex AI Gemini (LLM — replaces OpenRouter for gpt-parser + fake-prices)
# Auth via Application Default Credentials. Run once locally:
#   gcloud auth application-default login
# Production: Cloud Run service account inherits roles/aiplatform.user.
# ----------------------------------------------------------------------------
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-west1

# ----------------------------------------------------------------------------
# Google Vision API (OCR — already GCP)
# https://console.cloud.google.com/apis/library/vision.googleapis.com
# Server-only.
# ----------------------------------------------------------------------------
GOOGLE_VISION_API_KEY=

# Optional: path to a service account JSON file for Vision API.
# If set, takes precedence over GOOGLE_VISION_API_KEY.
GOOGLE_APPLICATION_CREDENTIALS=

# ----------------------------------------------------------------------------
# Inspector + admin
# ----------------------------------------------------------------------------
# Single shared password for the /inspect/* dashboard.
INSPECTOR_PASSWORD=
# Bearer token Cloud Scheduler sends to /api/admin/refresh.
REFRESH_TOKEN=

# ----------------------------------------------------------------------------
# OpenRouter — still in use by web/lib/receipts/llm-reviewer.mjs (Haiku 4.5
# with prompt caching + extended thinking). Other LLM call sites swapped
# to Vertex AI. To remove this dependency, swap llm-reviewer.mjs to Vertex.
# ----------------------------------------------------------------------------
OPENROUTER_KEY=

# ----------------------------------------------------------------------------
# USDA FoodData Central (seed scripts only)
# Free key from https://fdc.nal.usda.gov/api-key-signup
# DEMO_KEY works for ~10 requests; real key gets 3600/hr.
# ----------------------------------------------------------------------------
FDC_API_KEY=DEMO_KEY

# ----------------------------------------------------------------------------
# Legacy Supabase vars — kept as fallback so old .env.local files still work.
# Once PGHOST is set, scripts skip the Supabase derivation entirely.
# Required during data migration (web/scripts/migrate-from-supabase.mjs).
# ----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_DB_URL=
