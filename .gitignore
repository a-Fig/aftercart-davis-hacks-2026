# dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
coverage/

# next.js
.next/
out/
build/
dist/

# production
*.tsbuildinfo
next-env.d.ts

# env
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# secrets / credentials
*.pem
*-service-account.json
google-credentials*.json

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# os
.DS_Store
Thumbs.db
desktop.ini

# editors
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp

# vercel
.vercel

# seed data (real prices contributed by the community — never commit raw receipts)
db/seed/local/
db/seed/*.csv
!db/seed/example.csv

# ocr scratch
tmp/
*.tmp

# external datasets — large, downloaded locally, not committed
data/

# receipt photos — personal documents, kept locally only
# leading slash anchors to repo root so we don't match web/lib/receipts/ etc.
/receipts/
/legacy/v1/receipts/

# experiment receipt photos (re-rendered from receipts/)
/experiments/viewer/images/
/legacy/v1/experiments/viewer/images/

# claude code — user-local state only
.claude/

# reconstruct — local-only project link, not committed
.reconstruct/
